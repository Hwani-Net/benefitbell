# ──────────────────────────────────────────────────────────────────────────────
# 혜택알리미 (BenefitBell) 환경변수 템플릿
# 이 파일을 .env.local 로 복사 후 실제 값 입력
# Netlify 배포 시 대시보드에 환경변수 등록 필요
# ──────────────────────────────────────────────────────────────────────────────

# ── Firebase 클라이언트 SDK (NEXT_PUBLIC_ → 브라우저에 노출됨) ────────────────
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# ── Firebase FCM 웹 푸시 인증서 (Firebase 콘솔 → 프로젝트 설정 → 클라우드 메시징) ─
# "웹 구성" > Key Pair 에서 복사
NEXT_PUBLIC_FIREBASE_VAPID_KEY=

# ── Firebase Admin SDK (서버 전용 — 절대 NEXT_PUBLIC_ 금지) ──────────────────
# Firebase 콘솔 → 프로젝트 설정 → 서비스 계정 → 새 비공개 키 생성 → JSON 파일 내용 전체
# Vercel 에 등록할 때: JSON 한 줄 문자열로 변환 후 붙여넣기
FIREBASE_SERVICE_ACCOUNT_KEY=

# ── 카카오 OAuth ──────────────────────────────────────────────────────────────
# 카카오 개발자 콘솔 앱 ID: 1391024
KAKAO_CLIENT_ID=
KAKAO_CLIENT_SECRET=

# ── 공공데이터 포털 (data.go.kr) ──────────────────────────────────────────────
# 복지서비스 API 인증키 (Decoding 키)
DATA_GO_KR_SERVICE_KEY=

# ── OpenRouter AI (무료 tier) ──────────────────────────────────────────────────
# https://openrouter.ai/settings/keys 에서 API 키 발급 (무료, 카드 불필요)
# 무료 한도: 20 req/min, 200 req/day
OPENROUTER_API_KEY=

# ── 크론 보안 ─────────────────────────────────────────────────────────────────
# Netlify Cron 인증 헤더용 임의 비밀키 (예: openssl rand -base64 32)
CRON_SECRET=

# ── 프리미엄 활성화 시크릿 ─────────────────────────────────────────────────────
# self-claim 방지용 비밀키 (서버+클라이언트 동일 값)
PREMIUM_ACTIVATE_SECRET=
NEXT_PUBLIC_PREMIUM_ACTIVATE_SECRET=

# ── 토스페이먼츠 결제 ─────────────────────────────────────────────────────────
# 테스트 키 → 프로덕션 배포 전 반드시 live 키로 교체
TOSS_SECRET_KEY=

# ── Google Analytics (선택) ───────────────────────────────────────────────────
NEXT_PUBLIC_GA_ID=

# ── 카카오페이 프리미엄 링크 (선택) ───────────────────────────────────────────
NEXT_PUBLIC_KAKAOPAY_PREMIUM_LINK=

# ── Vercel KV (선택 — push-store 영속성을 위해) ────────────────────────────────
# Vercel 대시보드 → Storage → KV 생성 후 자동 주입됨
KV_REST_API_URL=
KV_REST_API_TOKEN=

# ── 레거시 / 제거 예정 ────────────────────────────────────────────────────────
# 아래 변수들은 FCM 전환 후 더 이상 필요하지 않음
# VAPID_PRIVATE_KEY=
# NEXT_PUBLIC_VAPID_PUBLIC_KEY=
# VAPID_SUBJECT=
# NEXT_PUBLIC_SUPABASE_URL=
# NEXT_PUBLIC_SUPABASE_ANON_KEY=
